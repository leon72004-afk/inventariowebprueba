generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    // "admin" | "operator"
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Business {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  logoUrl     String?
  address     String?
  phone       String?
  email       String?
  description String?
  bufferTime  Int      @default(15) // in minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  businessHours BusinessHours[]
  services      Service[]
  staff         Staff[]
  appointments  Appointment[]
  reviews       Review[]
  subscriptions Subscription[]
}

model BusinessHours {
  id         String   @id @default(uuid())
  businessId String
  dayOfWeek  Int      // 0 = Sunday, 1 = Monday, 2 = Tuesday, etc.
  openTime   String   // e.g. "08:00"
  closeTime  String   // e.g. "18:00"
  isClosed   Boolean  @default(false)
  
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model Service {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  price       Float
  duration    Int      // in minutes (e.g. 30, 45, 60, 90)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Staff {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  photoUrl    String?
  specialty   String?
  active      Boolean  @default(true)
  lunchStart  String?  // Optional lunch start path, e.g., "13:00"
  lunchEnd    String?  // Optional lunch end path, e.g., "14:00"
  breakStart  String?  // Optional break start time, e.g., "16:00"
  breakEnd    String?  // Optional break end time, e.g., "16:30"
  createdAt   DateTime @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  motorcycles  Motorcycle[]
  appointments Appointment[]
  reviews      Review[]
}

model Motorcycle {
  id         String   @id @default(uuid())
  brand      String
  model      String
  plate      String   @unique
  color      String
  customerId String
  createdAt  DateTime @default(now())

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Appointment {
  id           String   @id @default(uuid())
  businessId   String
  serviceId    String
  staffId      String?  // Nullable if "any available"
  customerId   String
  motorcycleId String
  date         DateTime // The specific date
  time         String   // e.g. "10:30"
  status       String   // "pending" | "completed" | "cancelled"
  notes        String?
  token        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff        Staff?       @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  motorcycle   Motorcycle   @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)
  reviews      Review[]
  notifications Notification[]
}

model Review {
  id            String   @id @default(uuid())
  businessId    String
  appointmentId String
  customerId    String
  rating        Int      // 1 to 5
  comment       String?
  createdAt     DateTime @default(now())

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String    @id @default(uuid())
  appointmentId String
  type          String    // "SMS" | "EMAIL"
  message       String
  recipient     String    // Phone or email
  status        String    // "pending" | "sent" | "failed"
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(uuid())
  businessId           String
  plan                 String    // "Básico" | "Premium" | "Pro"
  status               String    // "active" | "inactive" | "past_due"
  stripeSubscriptionId String?
  endsAt               DateTime?
  createdAt            DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Lead {
  id              String   @id @default(uuid())
  name            String
  email           String
  phone           String
  businessName    String
  city            String
  baysCount       Int      @default(1)
  washesPerDay    String?  // e.g. "10-20", "20-50", "50+"
  licenseTier     String?  // "Básico" | "Premium" | "Pro"
  additionalNotes String?
  status          String   @default("pending") // "pending" | "contacted" | "approved" | "rejected"
  createdAt       DateTime @default(now())
}
